{
  "info": {
    "_postman_id": "skill-bridge-api-collection",
    "name": "Skill Bridge API",
    "description": "Dokumentasi API Skill Bridge — Platform Edukasi Inklusi Anak Difabel (SDG #4 Quality Education)\n\n## Metode Autentikasi\n1. **JWT Bearer** — POST /api/login → gunakan token di header `Authorization: Bearer <token>`\n2. **Basic Auth** — POST /api/login/basic → header `Authorization: Basic base64(email:password)`\n3. **API Key** — header `X-API-Key: skillbridge-api-key-2024-secret`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://skill_bridge.test/api",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "skillbridge-api-key-2024-secret",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔐 1. Autentikasi",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', res.token);",
                  "    pm.test('Register berhasil', () => pm.expect(res).to.have.property('token'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Orang Tua Contoh\",\n  \"email\": \"orangtua@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/register",
              "host": ["{{base_url}}"],
              "path": ["register"]
            },
            "description": "Mendaftarkan akun orang tua baru. Mengembalikan JWT token."
          }
        },
        {
          "name": "Login (JWT Bearer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', res.access_token);",
                  "    pm.test('Login berhasil dan token tersedia', () => {",
                  "        pm.expect(res).to.have.property('access_token');",
                  "        pm.expect(res.token_type).to.equal('bearer');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"orangtua@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            },
            "description": "Login dengan email dan password. Mengembalikan JWT Bearer token untuk digunakan di endpoint lain."
          }
        },
        {
          "name": "Login (Basic Auth)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const res = pm.response.json();",
                  "    pm.collectionVariables.set('jwt_token', res.access_token);",
                  "    pm.test('Basic Auth login berhasil', () => pm.expect(res).to.have.property('access_token'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                { "key": "username", "value": "orangtua@example.com", "type": "string" },
                { "key": "password", "value": "password123", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/login/basic",
              "host": ["{{base_url}}"],
              "path": ["login", "basic"]
            },
            "description": "Login menggunakan HTTP Basic Authentication. Kirim kredensial di header `Authorization: Basic base64(email:password)`."
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/refresh",
              "host": ["{{base_url}}"],
              "path": ["refresh"]
            },
            "description": "Perbarui JWT token sebelum kedaluwarsa. Mengembalikan token baru."
          }
        },
        {
          "name": "Get User (Me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/me",
              "host": ["{{base_url}}"],
              "path": ["me"]
            },
            "description": "Mendapatkan informasi pengguna yang sedang login beserta data anak."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/logout",
              "host": ["{{base_url}}"],
              "path": ["logout"]
            },
            "description": "Membatalkan (invalidate) JWT token saat ini."
          }
        }
      ]
    },
    {
      "name": "🔑 2. API Key (Publik)",
      "item": [
        {
          "name": "Lessons Publik (via API Key)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/public/lessons",
              "host": ["{{base_url}}"],
              "path": ["public", "lessons"],
              "query": [
                { "key": "tipe_dunia", "value": "audio", "disabled": true },
                { "key": "tipe_dunia", "value": "visual", "disabled": true }
              ]
            },
            "description": "Mendapatkan daftar lesson tanpa JWT. Memerlukan header `X-API-Key`."
          }
        },
        {
          "name": "Modules Publik (via API Key)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-API-Key", "value": "{{api_key}}" }
            ],
            "url": {
              "raw": "{{base_url}}/public/modules",
              "host": ["{{base_url}}"],
              "path": ["public", "modules"]
            },
            "description": "Mendapatkan daftar modul tanpa JWT. Memerlukan header `X-API-Key`."
          }
        }
      ]
    },
    {
      "name": "👶 3. Children (Manajemen Data Anak)",
      "item": [
        {
          "name": "Daftar Children",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/children",
              "host": ["{{base_url}}"],
              "path": ["children"]
            }
          }
        },
        {
          "name": "Tambah Child",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nama_panggilan\": \"Budi\",\n  \"tanggal_lahir\": \"2019-05-10\",\n  \"jenis_disabilitas\": \"tunanetra\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/children",
              "host": ["{{base_url}}"],
              "path": ["children"]
            },
            "description": "jenis_disabilitas: 'tunanetra' (Audio World) atau 'tunarungu' (Visual World)"
          }
        },
        {
          "name": "Detail Child",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/children/1",
              "host": ["{{base_url}}"],
              "path": ["children", "1"]
            }
          }
        },
        {
          "name": "Update Child",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nama_panggilan\": \"Budi Santoso\",\n  \"tanggal_lahir\": \"2019-05-10\",\n  \"jenis_disabilitas\": \"tunarungu\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/children/1",
              "host": ["{{base_url}}"],
              "path": ["children", "1"]
            }
          }
        },
        {
          "name": "Hapus Child",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/children/1",
              "host": ["{{base_url}}"],
              "path": ["children", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "📊 4. Dashboard Orang Tua",
      "item": [
        {
          "name": "Dashboard Utama",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/dashboard",
              "host": ["{{base_url}}"],
              "path": ["dashboard"]
            }
          }
        },
        {
          "name": "Progress Per Anak",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/dashboard/child/1",
              "host": ["{{base_url}}"],
              "path": ["dashboard", "child", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "📚 5. Lessons",
      "item": [
        {
          "name": "Daftar Lessons (JWT)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/lessons?tipe_dunia=audio",
              "host": ["{{base_url}}"],
              "path": ["lessons"],
              "query": [
                { "key": "tipe_dunia", "value": "audio", "description": "Filter: audio atau visual" }
              ]
            }
          }
        },
        {
          "name": "Detail Lesson",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/lessons/1",
              "host": ["{{base_url}}"],
              "path": ["lessons", "1"]
            }
          }
        },
        {
          "name": "Selesaikan Lesson",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"child_id\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/lessons/1/complete",
              "host": ["{{base_url}}"],
              "path": ["lessons", "1", "complete"]
            }
          }
        },
        {
          "name": "Mulai Sesi Belajar",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"child_id\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/lessons/1/start-session",
              "host": ["{{base_url}}"],
              "path": ["lessons", "1", "start-session"]
            }
          }
        },
        {
          "name": "Akhiri Sesi Belajar",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/sessions/1/end",
              "host": ["{{base_url}}"],
              "path": ["sessions", "1", "end"]
            }
          }
        }
      ]
    },
    {
      "name": "🧩 6. Quiz",
      "item": [
        {
          "name": "Kirim Jawaban Quiz",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"child_id\": 1,\n  \"lesson_id\": 1,\n  \"quiz_question_id\": 1,\n  \"jawaban_anak\": \"kucing\",\n  \"benar\": true,\n  \"skor\": 100,\n  \"percobaan\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/quiz/answer",
              "host": ["{{base_url}}"],
              "path": ["quiz", "answer"]
            }
          }
        },
        {
          "name": "Hasil Quiz",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/quiz/results?child_id=1&lesson_id=1",
              "host": ["{{base_url}}"],
              "path": ["quiz", "results"],
              "query": [
                { "key": "child_id", "value": "1" },
                { "key": "lesson_id", "value": "1" }
              ]
            }
          }
        }
      ]
    }
  ]
}
